{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Copilot & Agent Day Lab Catalog",
  "type": "object",
  "required": ["version", "event", "labs"],
  "properties": {
    "version": { "type": "string" },
    "event": {
      "type": "object",
      "required": ["name", "date"],
      "properties": {
        "name": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "description": { "type": "string" }
      }
    },
    "links": {
      "type": "object",
      "properties": {
        "guideTopicsBase": { "type": "string" },
        "labsBase": { "type": "string" }
      }
    },
    "labs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "owner", "guide"],
        "properties": {
          "id": { "type": "string", "description": "guide/topics/<id> 폴더명과 일치" },
          "code": { "type": "string", "description": "랩 코드 (A~F)" },
          "order": { "type": "integer" },
          "title": { "type": "string" },
          "summary": { "type": "string" },
          "owner": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": { "type": "string" },
              "github": { "type": ["string", "null"], "description": "담당자 GitHub URL (없으면 null)" }
            }
          },
          "guide": {
            "type": "object",
            "required": ["path"],
            "properties": {
              "path": { "type": "string", "description": "이미 배포된 교안 경로" },
              "handsOn": { "type": "string", "description": "실습 링크 (현재는 배포 교안 경로)" }
            }
          },
          "original": { "$ref": "#/definitions/fileList", "description": "원본 교안" },
          "samples": { "$ref": "#/definitions/fileList", "description": "샘플 파일" },
          "solution": { "$ref": "#/definitions/fileList", "description": "솔루션 파일" }
        }
      }
    }
  },
  "definitions": {
    "fileList": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "path"],
        "properties": {
          "name": { "type": "string" },
          "path": { "type": "string", "description": "repo 루트 기준 상대 경로" }
        }
      }
    }
  }
}
